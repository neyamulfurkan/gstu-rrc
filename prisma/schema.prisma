// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ClubConfig {
  id                       String   @id @default("main")
  clubName                 String   @default("GSTU Robotics & Research Club")
  clubShortName            String   @default("GSTU RRC")
  clubMotto                String   @default("Innovate. Build. Inspire.")
  clubDescription          String   @default("") @db.Text
  universityName           String   @default("Gopalganj Science and Technology University")
  universityLogoUrl        String   @default("")
  universityWebUrl         String   @default("")
  departmentName           String   @default("Computer Science & Engineering")
  foundedYear              Int      @default(2019)
  address                  String   @default("") @db.Text
  email                    String   @default("")
  phone                    String   @default("")
  logoUrl                  String   @default("")
  faviconUrl               String   @default("")
  fbUrl                    String   @default("")
  ytUrl                    String   @default("")
  igUrl                    String   @default("")
  liUrl                    String   @default("")
  ghUrl                    String   @default("")
  twitterUrl               String   @default("")
  extraSocialLinks         Json     @default("[]")
  metaDescription          String   @default("")
  seoKeywords              String   @default("")
  gscVerifyTag             String   @default("")
  ogImageUrl               String   @default("")
  regStatus                String   @default("open")
  membershipFee            Int      @default(200)
  bkashNumber              String   @default("")
  bkashName                String   @default("")
  nagadNumber              String   @default("")
  nagadName                String   @default("")
  requireScreenshot        Boolean  @default(true)
  autoApprove              Boolean  @default(false)
  maxUploadMb              Int      @default(10)
  welcomeEmailSubject      String   @default("Welcome to the Club!")
  welcomeEmailBody         String   @default("") @db.Text
  heroType                 String   @default("slideshow")
  heroVideoUrl             String   @default("")
  heroFallbackImg          String   @default("")
  heroImages               Json     @default("[]")
  heroCtaLabel1            String   @default("Join Us")
  heroCtaUrl1              String   @default("/membership")
  heroCtaLabel2            String   @default("Explore Projects")
  heroCtaUrl2              String   @default("/projects")
  overlayOpacity           Int      @default(60)
  colorConfig              Json     @default("{}")
  displayFont              String   @default("Orbitron")
  bodyFont                 String   @default("DM Sans")
  monoFont                 String   @default("JetBrains Mono")
  headingFont              String   @default("Syne")
  animationStyle           String   @default("standard")
  transitionStyle          String   @default("fade")
  particleEnabled          Boolean  @default(true)
  particleCount            Int      @default(80)
  particleSpeed            Float    @default(0.5)
  particleColor            String   @default("accent")
  announcementTickerSpeed  Int      @default(40)
  privacyPolicy            String   @default("") @db.Text
  termsOfUse               String   @default("") @db.Text
  footerCopyright          String   @default("")
  constitutionUrl          String   @default("")
  groqApiKey               String   @default("")
  groqModel                String   @default("llama3-70b-8192")
  groqTemperature          Float    @default(0.7)
  aiSystemPrompt           String   @default("") @db.Text
  aiEnabled                Boolean  @default(true)
  aiContextItems           Json     @default("{\"events\":true,\"projects\":true,\"committee\":true,\"advisors\":true,\"announcements\":true,\"instruments\":true,\"membership\":true}")
  aiChatHistory            String   @default("session")
  fbPageId                 String   @default("")
  fbPageName               String   @default("")
  fbPageToken              String   @default("") @db.Text
  fbWebhookToken           String   @default("")
  fbAutoPost               Json     @default("{\"events\":false,\"projects\":false,\"announcements\":false,\"gallery\":false}")
  fbRequireApproval        Boolean  @default(false)
  fbAutoPostTemplates      Json     @default("{}")
  fbAutoReplyComments      Boolean  @default(false)
  fbCommentSystemPrompt    String   @default("") @db.Text
  fbCommentReplyDelay      Int      @default(0)
  fbAutoReplyMessages      Boolean  @default(false)
  fbMessageSystemPrompt    String   @default("") @db.Text
  fbGreetingMessage        String   @default("") @db.Text
  fbFallbackMessage        String   @default("") @db.Text
  resendApiKey             String   @default("")
  resendFromEmail          String   @default("")
  resendFromName           String   @default("")
  emailTemplates           Json     @default("{}")
  defaultMemberRoleId      String   @default("")
  updatedAt                DateTime @updatedAt
}

model Role {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#7B8DB0")
  category  String   @default("general")
  sortOrder Int      @default(0)
  members   Member[]

  @@index([category])
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  shortName String?
  members   Member[]
}

model AdminRole {
  id          String   @id @default(cuid())
  name        String   @unique
  color       String   @default("#00E5FF")
  permissions Json     @default("{}")
  members     Member[]
}

model Member {
  id               String         @id @default(cuid())
  username         String         @unique
  email            String         @unique
  passwordHash     String
  fullName         String
  studentId        String
  phone            String
  gender           String?
  dob              DateTime?
  address          String?        @db.Text
  avatarUrl        String
  coverUrl         String         @default("")
  bio              String?        @db.Text
  interests        String?
  skills           Json           @default("[]")
  socialLinks      Json           @default("{}")
  departmentId     String
  department       Department     @relation(fields: [departmentId], references: [id])
  session          String
  roleId           String
  role             Role           @relation(fields: [roleId], references: [id])
  memberType       String         @default("member")
  status           String         @default("active")
  adminNotes       String?        @db.Text
  workplace        String?
  isAdmin          Boolean        @default(false)
  adminRoleId      String?
  adminRole        AdminRole?     @relation(fields: [adminRoleId], references: [id])
  createdAt        DateTime       @default(now())
  lastLogin        DateTime?
  posts            Post[]
  comments         Comment[]
  likes            Like[]
  applications     Application[]
  certificates     Certificate[]
  borrowRequests      BorrowRequest[]
  memberBorrowRequests BorrowRequest[] @relation("BorrowRequestMember")
  borrowedInstruments Instrument[]
  galleryUploads      GalleryItem[]
  committeeEntries CommitteeMember[]
  notifications    Notification[]
  adminActions        AuditLog[]
  passwordResetTokens PasswordResetToken[]
  adminRoleRequests   AdminRoleRequest[]
  eventsAttended   Event[]        @relation("EventAttendees")
  projectsTeam     Project[]      @relation("ProjectTeam")

  @@index([username])
  @@index([email])
  @@index([roleId])
  @@index([departmentId])
  @@index([status])
  @@index([memberType])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id])
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
}

model Application {
  id            String    @id @default(cuid())
  fullName      String
  studentId     String
  email         String
  phone         String
  gender        String?
  dob           DateTime?
  address       String?   @db.Text
  avatarUrl     String
  departmentId  String
  session       String
  memberType    String
  username      String
  passwordHash  String
  paymentMethod String
  transactionId String
  senderPhone   String
  screenshotUrl String
  status        String    @default("pending")
  adminNote     String?
  memberId      String?
  member        Member?   @relation(fields: [memberId], references: [id])
  createdAt     DateTime  @default(now())
  reviewedAt    DateTime?

  @@index([status])
  @@index([email])
}

model EventCategory {
  id     String  @id @default(cuid())
  name   String  @unique
  color  String  @default("#00E5FF")
  events Event[]
}

model Event {
  id                   String        @id @default(cuid())
  title                String
  slug                 String        @unique
  coverUrl             String
  categoryId           String
  category             EventCategory @relation(fields: [categoryId], references: [id])
  startDate            DateTime
  endDate              DateTime?
  allDay               Boolean       @default(false)
  venue                String
  mapLink              String?
  organizerName        String
  organizerId          String?
  description          Json          @default("{}")
  registrationEnabled  Boolean       @default(false)
  registrationDeadline DateTime?
  metaDescription      String?
  isPublished          Boolean       @default(false)
  galleryItems         GalleryItem[]
  attendees            Member[]      @relation("EventAttendees")
  createdAt            DateTime      @default(now())

  @@index([slug])
  @@index([startDate])
  @@index([isPublished])
  @@index([categoryId])
}

model ProjectCategory {
  id       String    @id @default(cuid())
  name     String    @unique
  color    String    @default("#00E5FF")
  projects Project[]
}

model Project {
  id           String          @id @default(cuid())
  title        String
  slug         String          @unique
  coverUrl     String
  categoryId   String
  category     ProjectCategory @relation(fields: [categoryId], references: [id])
  status       String
  year         Int
  teamMembers  Member[]        @relation("ProjectTeam")
  technologies Json            @default("[]")
  description  Json            @default("{}")
  githubUrl    String?
  demoUrl      String?
  reportUrl    String?
  youtubeUrl   String?
  galleryItems GalleryItem[]
  milestones   Json            @default("[]")
  isPublished  Boolean         @default(false)
  createdAt    DateTime        @default(now())

  @@index([slug])
  @@index([status])
  @@index([isPublished])
  @@index([categoryId])
}

model GalleryCategory {
  id    String        @id @default(cuid())
  name  String        @unique
  color String        @default("#00E5FF")
  items GalleryItem[]
}

model GalleryItem {
  id              String          @id @default(cuid())
  url             String
  type            String
  title           String?
  description     String?         @db.Text
  altText         String
  categoryId      String
  category        GalleryCategory @relation(fields: [categoryId], references: [id])
  tags            Json            @default("[]")
  uploaderId      String?
  uploader        Member?         @relation(fields: [uploaderId], references: [id])
  eventId         String?
  event           Event?          @relation(fields: [eventId], references: [id])
  projectId       String?
  project         Project?        @relation(fields: [projectId], references: [id])
  status          String          @default("pending")
  isAdminUpload   Boolean         @default(false)
  year            Int
  downloadEnabled Boolean         @default(false)
  createdAt       DateTime        @default(now())

  @@index([status])
  @@index([type])
  @@index([uploaderId])
  @@index([eventId])
  @@index([projectId])
  @@index([categoryId])
}

model Post {
  id        String    @id @default(cuid())
  authorId  String
  author    Member    @relation(fields: [authorId], references: [id])
  content   String    @db.Text
  mediaUrls Json      @default("[]")
  mediaType String?
  isPinned  Boolean   @default(false)
  isDeleted Boolean   @default(false)
  likes     Like[]
  comments  Comment[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([authorId])
  @@index([isPinned])
  @@index([createdAt])
  @@index([isDeleted])
}

model Comment {
  id        String    @id @default(cuid())
  postId    String
  post      Post      @relation(fields: [postId], references: [id])
  authorId  String
  author    Member    @relation(fields: [authorId], references: [id])
  content   String    @db.Text
  parentId  String?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  likes     Like[]
  isDeleted Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
}

model Like {
  id        String   @id @default(cuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id])
  postId    String?
  post      Post?    @relation(fields: [postId], references: [id])
  commentId String?
  comment   Comment? @relation(fields: [commentId], references: [id])
  createdAt DateTime @default(now())

  @@unique([memberId, postId])
  @@unique([memberId, commentId])
  @@index([postId])
  @@index([commentId])
}

model AnnouncementCategory {
  id            String         @id @default(cuid())
  name          String         @unique
  color         String         @default("#00E5FF")
  announcements Announcement[]
}

model Announcement {
  id          String               @id @default(cuid())
  title       String
  content     Json                 @default("{}")
  excerpt     String               @default("") @db.Text
  categoryId  String
  category    AnnouncementCategory @relation(fields: [categoryId], references: [id])
  expiresAt   DateTime?
  isPublished Boolean              @default(false)
  sendEmail   Boolean              @default(false)
  createdAt   DateTime             @default(now())

  @@index([isPublished])
  @@index([expiresAt])
  @@index([categoryId])
}

model InstrumentCategory {
  id          String       @id @default(cuid())
  name        String       @unique
  color       String       @default("#00E5FF")
  instruments Instrument[]
}

model AdminRoleRequest {
  id        String   @id @default(cuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id])
  reason    String   @db.Text
  status    String   @default("pending")
  createdAt DateTime @default(now())

  @@index([memberId])
  @@index([status])
}

model Instrument {
  id          String             @id @default(cuid())
  name        String
  categoryId  String
  category    InstrumentCategory @relation(fields: [categoryId], references: [id])
  description String             @default("") @db.Text
  imageUrl    String
  status      String             @default("available")
  borrowerId  String?
  borrower    Member?            @relation(fields: [borrowerId], references: [id])
  borrowDate  DateTime?
  returnDate  DateTime?
  requests    BorrowRequest[]
  createdAt   DateTime           @default(now())

  @@index([status])
  @@index([categoryId])
}

model BorrowRequest {
  id           String     @id @default(cuid())
  instrumentId String
  instrument   Instrument @relation(fields: [instrumentId], references: [id])
  requesterId  String
  requester    Member     @relation(fields: [requesterId], references: [id])
  memberId     String?
  member       Member?    @relation("BorrowRequestMember", fields: [memberId], references: [id])
  purpose      String     @db.Text
  borrowDate   DateTime
  returnDate   DateTime
  notes        String?    @db.Text
  status       String     @default("pending")
  adminNote    String?
  createdAt    DateTime   @default(now())

  @@index([instrumentId])
  @@index([requesterId])
  @@index([status])
}

model CertificateTemplate {
  id           String        @id @default(cuid())
  name         String
  type         String
  htmlContent  String        @db.Text
  cssContent   String        @db.Text
  previewUrl   String?
  certificates Certificate[]
  createdAt    DateTime      @default(now())
}

model Certificate {
  id                  String              @id @default(cuid())
  serial              String              @unique
  recipientId         String
  recipient           Member              @relation(fields: [recipientId], references: [id])
  templateId          String
  template            CertificateTemplate @relation(fields: [templateId], references: [id])
  achievement         String
  issuedAt            DateTime            @default(now())
  signedByName        String
  signedByDesignation String
  signatureUrl        String
  pdfUrl              String
  isRevoked           Boolean             @default(false)

  @@index([serial])
  @@index([recipientId])
  @@index([isRevoked])
}

model Notification {
  id        String   @id @default(cuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id])
  type      String
  title     String
  body      String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([memberId])
  @@index([isRead])
  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  adminId     String
  admin       Member   @relation(fields: [adminId], references: [id])
  actionType  String
  description String   @db.Text
  entityType  String?
  entityId    String?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([adminId])
  @@index([actionType])
  @@index([createdAt])
}

model CommitteeMember {
  id            String  @id @default(cuid())
  memberId      String?
  member        Member? @relation(fields: [memberId], references: [id])
  memberName    String
  designation   String
  committeeType String
  session       String?
  sessionYear   String?
  sortOrder     Int     @default(0)

  @@index([committeeType])
  @@index([session])
}

model Advisor {
  id                String   @id @default(cuid())
  name              String
  designation       String
  institution       String
  photoUrl          String
  bio               String   @db.Text
  researchInterests Json     @default("[]")
  email             String?
  socialLinks       Json     @default("{}")
  isCurrent         Boolean  @default(true)
  periodStart       Int?
  periodEnd         Int?
  sortOrder         Int      @default(0)

  @@index([isCurrent])
}

model ClubMilestone {
  id          String  @id @default(cuid())
  date        String
  sortOrder   Int
  title       String
  description String  @db.Text
  imageUrl    String?
}

model Achievement {
  id          String  @id @default(cuid())
  icon        String
  title       String
  description String  @db.Text
  year        Int
  link        String?
  sortOrder   Int     @default(0)
}

model WhyJoinCard {
  id           String  @id @default(cuid())
  icon         String
  heading      String
  description  String  @db.Text
  learnMoreUrl String?
  sortOrder    Int     @default(0)
}

model AlumniSpotlight {
  id       String @id @default(cuid())
  memberId String?
  name     String
  position String
  company  String
  quote    String @db.Text
  photoUrl String
  session  String
  sortOrder Int   @default(0)
}

model CustomCardSection {
  id          String       @id @default(cuid())
  targetPage  String
  heading     String?
  subtitle    String?
  position    String       @default("before_footer")
  isPublished Boolean      @default(false)
  sortOrder   Int          @default(0)
  cards       CustomCard[]
}

model CustomCard {
  id          String            @id @default(cuid())
  sectionId   String
  section     CustomCardSection @relation(fields: [sectionId], references: [id])
  heading     String
  description Json              @default("{}")
  imageUrl    String?
  buttonLabel String?
  buttonUrl   String?
  buttonStyle String?           @default("primary")
  sortOrder   Int               @default(0)
}

model EmailLog {
  id           String   @id @default(cuid())
  to           String
  subject      String
  templateName String
  status       String
  sentAt       DateTime @default(now())

  @@index([sentAt])
}

model FacebookPendingPost {
  id          String    @id @default(cuid())
  entityType  String
  entityId    String
  entityTitle String
  message     String    @db.Text
  imageUrl    String?
  link        String
  status      String    @default("pending")
  postedAt    DateTime?
  fbPostId    String?
  adminNote   String?
  createdAt   DateTime  @default(now())

  @@index([status])
  @@index([entityType])
  @@index([createdAt])
}